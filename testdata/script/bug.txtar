# Help flag.
exec garble bug -h
stderr 'Usage of .garble bug.'
stderr '-n'
stderr '-full-env'
! stdout .

# Unknown flag.
! exec garble bug -bogus
stderr 'flag provided but not defined'
! stdout .

# Unexpected positional argument.
! exec garble bug extra
stderr 'Usage of .garble bug.'
! stdout .

# -n prints a Markdown-rendered bug report to stdout.
exec garble bug -n
stdout 'Output of .garble version.'
stdout 'Output of .go env. in your module/workspace'
stdout 'What did you do'
stdout 'What did you see happen'
stdout 'What did you expect to see'
stdout 'mvdan.cc/garble'
stdout 'GOOS='
stdout 'GOARCH='
! stderr .

# -n -full-env includes variables not in the default whitelist.
exec garble bug -n -full-env
stdout 'GOCACHE='

# By default, path-heavy variables are excluded.
exec garble bug -n
! stdout 'GOCACHE='
! stdout 'GOMODCACHE='

-- go.mod --
module dummy

go 1.26
