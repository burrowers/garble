+// garbleSymbolMap maps obfuscated "pkg.func" to original "pkg.func" for intrinsic lookup.
+// Populated from GARBLE_SYMBOL_MAP environment variable.
+var garbleSymbolMap map[string]string
+
+func init() {
+	garbleSymbolMap = make(map[string]string)
+	if mapStr := os.Getenv("GARBLE_SYMBOL_MAP"); mapStr != "" {
+		for _, mapping := range strings.Split(mapStr, ",") {
+			if mapping == "" {
+				continue
+			}
+			parts := strings.SplitN(mapping, "=", 2)
+			if len(parts) == 2 && parts[0] != "" && parts[1] != "" {
+				garbleSymbolMap[parts[0]] = parts[1]
+			}
+		}
+	}
+}
+
+// translateGarbleSymbol translates an obfuscated pkg.fn to original pkg.fn.
+func translateGarbleSymbol(pkg, fn string) (string, string) {
+	if len(garbleSymbolMap) == 0 {
+		return pkg, fn
+	}
+	key := pkg + "." + fn
+	if orig, ok := garbleSymbolMap[key]; ok {
+		if idx := strings.LastIndex(orig, "."); idx > 0 {
+			return orig[:idx], orig[idx+1:]
+		}
+	}
+	return pkg, fn
+}
