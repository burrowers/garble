+// garblePkgPathMap maps obfuscated package paths to original paths.
+// Populated from GARBLE_PKGPATH_MAP environment variable.
+var garblePkgPathMap map[string]string
+
+func init() {
+	garblePkgPathMap = make(map[string]string)
+	if mapStr := os.Getenv("GARBLE_PKGPATH_MAP"); mapStr != "" {
+		for _, entry := range strings.Split(mapStr, ",") {
+			parts := strings.SplitN(entry, "=", 2)
+			if len(parts) == 2 {
+				garblePkgPathMap[parts[0]] = parts[1]
+			}
+		}
+	}
+}
+
+// TranslateGarblePkgPath returns the original package path for an obfuscated path.
+func TranslateGarblePkgPath(pkgpath string) string {
+	if orig, ok := garblePkgPathMap[pkgpath]; ok {
+		return orig
+	}
+	return pkgpath
+}
